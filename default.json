{
  "extends": [
    "config:base",
    ":dependencyDashboard",
    ":disableRateLimiting",
    "docker:enableMajor",
    ":enablePreCommit",
    "helpers:pinGitHubActionDigests",
    "helpers:githubDigestChangelogs",
    "github>zekker6/renovate-config:commit-message",
    "github>zekker6/renovate-config:pr-labels",
    "github>zekker6/renovate-config:semantic-commits",
    "github>zekker6/renovate-config:generic-regex-manager"
  ],
  "onboarding": false,
  "requireConfig": "optional",
  "assignees": ["zekker6"],
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": ["prIgnoreNotification"],
  "commitBodyTable": true,
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "description": "Automerge dev tool minor and patch updates",
      "matchPackageNames": [
          "nektos/act",
          "golangci/golangci-lint",
          "go-task/task",
          "goreleaser/goreleaser",
          "air-verse/air",
          "shfmt",
          "mvdan/sh",
          "golang/go",
          "go"
        ],
      "automerge": true,
      "automergeType": "branch",
      "requiredStatusChecks": null,
      "matchUpdateTypes": ["minor", "patch"]
    }
  ]
}
