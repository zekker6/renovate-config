{
  "packageRules": [
    {
      "description": "Automerge dev tool minor and patch updates",
      "matchPackageNames": [
          "nektos/act",
          "golangci/golangci-lint",
          "go-task/task",
          "goreleaser/goreleaser",
          "air-verse/air",
          "shfmt",
          "mvdan/sh",
          "golang/go",
          "go",
          "modelcontextprotocol/inspector"
        ],
      "automerge": true,
      "automergeType": "branch",
      "requiredStatusChecks": null,
      "matchUpdateTypes": ["minor", "patch"]
    }
  ]
}
